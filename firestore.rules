rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "compilewebtech@gmail.com";
    }

    match /sponsors/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
